# =============================================================================
# Atlas RAG System - Environment Variables
# =============================================================================
# These defaults allow `docker compose up` to work immediately after cloning.
# For production, change DB_PASSWORD and AUTH_SECRET_KEY to secure values.
# =============================================================================

# PostgreSQL password
DB_PASSWORD=atlas

# JWT secret key for authentication (generate with: openssl rand -hex 32)
AUTH_SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32

# Default admin password on first start
ADMIN_DEFAULT_PASSWORD=admin

# =============================================================================
# Hugging Face Token (optional, required for gated models)
# =============================================================================
# Generate at: https://huggingface.co/settings/tokens
HF_TOKEN=

# =============================================================================
# LLM - llama.cpp CUDA server (port 8080)
# =============================================================================
# Model is downloaded automatically from HF on first start and cached in ../models/.
# hf.co/unsloth/Qwen3.5-35B-A3B-GGUF:UD-IQ3_S is loaded with --jinja to enable
# thinking control via the model's Jinja2 chat template (enable_thinking param).
LLM_N_GPU_LAYERS=-1          # -1 = offload all layers to GPU
LLM_CTX_SIZE=65536

# =============================================================================
# Embedding - Text Embeddings Inference CPU server (port 8081)
# =============================================================================
# perplexity-ai/pplx-embed-context-v1-4b is downloaded automatically on first
# start and cached in the embed_model_cache Docker volume.
# Output: 2560-dimensional embeddings.

# =============================================================================
# Docling API Configuration
# =============================================================================

# OCR for scanned documents and images
DOCLING_DO_OCR=true
DOCLING_OCR_BACKEND=auto               # "auto" (best available), "easyocr" (GPU), "tesseract"
DOCLING_OCR_LANG=                      # Comma-separated: "de,en" (empty = auto-detect)

# Table structure recognition
DOCLING_DO_TABLE_STRUCTURE=true
DOCLING_TABLE_MODE=fast                # "fast" (TableFormer-fast) or "accurate" (slower, better)

# Code block detection
DOCLING_DO_CODE_ENRICHMENT=true

# Accelerator device for Docling layout analysis (forced to cpu in compose)
DOCLING_ACCELERATOR_DEVICE=cpu
DOCLING_FLASH_ATTENTION=false

# GPU batch sizes (increase on high-VRAM GPUs for throughput)
DOCLING_OCR_BATCH_SIZE=4
DOCLING_LAYOUT_BATCH_SIZE=4
DOCLING_TABLE_BATCH_SIZE=4

# Per-document timeout (seconds, 0 = no limit)
DOCLING_DOCUMENT_TIMEOUT=300

# Image processing
DOCLING_IMAGES_SCALE=2.0               # Scale factor for rasterized page images
DOCLING_GENERATE_PICTURES=false        # Extract embedded images from documents

# Model warmup on container start (avoids cold-start latency)
DOCLING_WARMUP=true
