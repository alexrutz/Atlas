# =============================================================================
# Atlas RAG System - Environment Variables
# =============================================================================
# These defaults allow `docker compose up` to work immediately after cloning.
# For production, change DB_PASSWORD and AUTH_SECRET_KEY to secure values.
# =============================================================================

# PostgreSQL password
DB_PASSWORD=atlas

# JWT secret key for authentication (generate with: openssl rand -hex 32)
AUTH_SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32

# Default admin password on first start
ADMIN_DEFAULT_PASSWORD=admin

# =============================================================================
# Model Selection  (GGUF files must exist in the ../models bind volume)
# =============================================================================

# ── LLM model ──────────────────────────────────────────────────────────────
# Default chat / reasoning model served on port 8080.
LLM_MODEL=Qwen3.5-35B-A3B-UD-IQ3_S.gguf
LLM_CTX_SIZE=65536
LLM_PREDICT=65536

# ── Embedding model ────────────────────────────────────────────────────────
# Model served on port 8081 with --embedding.
# Options (uncomment ONE block):
#
#   pplx-embed-context-v1-0.6b-q8_0.gguf          (text-only, 1024-dim)
#   EMBED_MODEL=pplx-embed-context-v1-0.6b-q8_0.gguf
#   EMBED_CTX_SIZE=32768
#   EMBED_EXTRA_ARGS=
#
#   GLM-OCR-Q8_0.gguf                              (0.9B, OCR VLM)
#   EMBED_MODEL=GLM-OCR-Q8_0.gguf
#   EMBED_CTX_SIZE=32768
#   EMBED_EXTRA_ARGS=--mmproj /models/mmproj-GLM-OCR-Q8_0.gguf
#
#   PaddleOCR-VL-1.5-Q8_0.gguf                     (0.5B, OCR VLM)
#   EMBED_MODEL=PaddleOCR-VL-1.5-Q8_0.gguf
#   EMBED_CTX_SIZE=32768
#   EMBED_EXTRA_ARGS=--mmproj /models/PaddleOCR-VL-1.5-mmproj.gguf
#
#   Qianfan-OCR-Q8_0.gguf                          (4B, OCR VLM, Layout-as-thought)
EMBED_MODEL=Qianfan-OCR-Q8_0.gguf
EMBED_CTX_SIZE=32768
EMBED_EXTRA_ARGS=--mmproj /models/mmproj-Qianfan-OCR-Q8_0.gguf
