# =============================================================================
# Atlas RAG System - Umgebungsvariablen
# =============================================================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
# =============================================================================

# PostgreSQL Passwort (PFLICHT - bitte ändern!)
DB_PASSWORD=atlas_sicheres_passwort_hier_aendern

# JWT Secret Key für Authentifizierung (PFLICHT - bitte generieren!)
# Generieren mit: openssl rand -hex 32
AUTH_SECRET_KEY=bitte_mit_openssl_rand_hex_32_generieren

# Standard-Admin-Passwort beim ersten Start (danach ändern!)
ADMIN_DEFAULT_PASSWORD=Admin123!
